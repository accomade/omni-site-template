{
	"name": "omni-site-template",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "cd fonts-generator && ./fonts",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/js-cookie": "^3.0.6",
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.9.1",
		"@types/squirrelly": "^8.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"vite": "^8.0.13"
	},
	"dependencies": {
		"@fontsource/arizonia": "^5.2.8",
		"@fontsource/carrois-gothic": "^5.2.8",
		"@fontsource/raleway": "^5.2.8",
		"@sveltejs/adapter-static": "^3.0.10",
		"@twicpics/components": "^0.33.0",
		"accomadesc": "^0.4.16",
		"gdpr-cooco-banner": "^0.0.13",
		"js-cookie": "^3.0.7",
		"luxon": "^3.7.2"
	}
}
